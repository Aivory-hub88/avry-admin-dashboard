# Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon (public) key — safe to expose to browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — SERVER-SIDE ONLY, never expose to client
SUPABASE_SERVICE_ROLE_KEY=

# Aivory backend base URL (no trailing slash)
NEXT_PUBLIC_API_URL=

# Per-microservice base URLs (no trailing slash).
# Each admin BFF route calls its dedicated service. When unset, the route
# falls back to NEXT_PUBLIC_API_URL.
BACKEND_SERVICE_URL=
PAYMENTS_SERVICE_URL=
DIAGNOSTICS_SERVICE_URL=
BLUEPRINT_SERVICE_URL=
ROADMAP_SERVICE_URL=
WORKFLOWS_SERVICE_URL=
BLOG_SERVICE_URL=
CAREERS_SERVICE_URL=

# Secret token for the /api/admin/setup-user utility route
# Generate with: openssl rand -hex 32
SETUP_SECRET=
